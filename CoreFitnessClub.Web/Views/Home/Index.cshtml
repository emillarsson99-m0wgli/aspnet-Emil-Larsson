@{
    ViewData["Title"] = "Home Page";
}

@section Styles {
    <link rel="stylesheet" href="~/css/HomePage.css" />
}

<main class="site-hero">
    <div class="hero-container">
        <div class="hero-text-container">
            <div class="hero-box">
                <img src="~/images/accent-bullet.svg" alt="" />
                <p>Strong Body, Strong Mind.</p>
            </div>

            <h1>Build Strength Boost Confidence Today!</h1>

            <p>
                Begin your fitness journey with expert trainers, modern equipment, and a supportive
                environment designed to help you build strength and confidence.
            </p>

            <div class="bullet-container">
                <div class="hero-bullet">
                    <img src="~/images/checkmark.svg" alt="" />
                    <p>Transform your body with training</p>
                </div>

                <div class="hero-bullet">
                    <img src="~/images/checkmark.svg" alt="" />
                    <p>Personal training for real results</p>
                </div>

                <div class="hero-bullet">
                    <img src="~/images/checkmark.svg" alt="" />
                    <p>Build confidence through fitness</p>
                </div>

                <div class="hero-bullet">
                    <img src="~/images/checkmark.svg" alt="" />
                    <p>Fitness tailored to your goals</p>
                </div>
            </div>

            <a asp-controller="Account" asp-action="Register" class="button">
                Get Started &gt;
            </a>
        </div>

        <div class="hero-image">
            <img src="~/images/hero-models.svg" alt="Fitness models" />
        </div>
    </div>
</main>

<section class="brands-bg">
    <div class="brands-container">
        <div class="brands">
            <img src="~/images/Logoipsum1.svg" alt="Logo 1" />
            <img src="~/images/Logoipsum2.svg" alt="Logo 2" />
            <img src="~/images/Logoipsum3.svg" alt="Logo 3" />
            <img src="~/images/Logoipsum4.svg" alt="Logo 4" />
            <img src="~/images/Logoipsum5.svg" alt="Logo 5" />
        </div>

        <div class="brands-txt">
            <p>Modern Equipment</p>
        </div>
    </div>
</section>

<section class="about-us-bg">
    <div class="about-us-container">
        <div class="about-us-img">
            <img src="~/images/aboutus-img.svg" alt="About us" />
        </div>

        <div class="about-us-txt">
            <div class="aboutus-bullet">
                <img src="~/images/accent-bullet.svg" alt="" />
                <p>About Us</p>
            </div>

            <div class="aboutus-title-box">
                <h2>Elevating Fitness Journey with Expert Guidance</h2>
                <p>
                    We support every stage of your fitness journey with certified trainers,
                    personalized programs proven methods designed to help you train safely,
                    build strength.
                </p>
            </div>

            <div class="aboutus-box">
                <img class="aboutus-quote" src="~/images/about-body-quote.svg" alt="Quote" />
                <p class="aboutus-box-txt">
                    Our mission is to transform lives by combining expert guidance, powerful
                    training programs, and a motivating community that helps you grow stronger
                    every day.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="program-bg">
    <div class="program-container">
        <div class="program-bullet">
            <img src="~/images/accent-bullet.svg" alt="" />
            <p>Our Programs</p>
        </div>

        <h2>Professional training program for stronger health</h2>

        <div class="program-img">
            <img src="~/images/program-image-1.svg" alt="Program 1" />
            <img src="~/images/program-image-2.svg" alt="Program 2" />
            <img src="~/images/program-image-3.svg" alt="Program 3" />
        </div>

        <div class="program-description">
            <p>Let's make something great work together.</p>
            <a asp-controller="Home" asp-action="NotFoundPage" class="free-quote">Get Free Quote</a>
        </div>
    </div>
</section>

<section class="store-bg">
    <div class="store-container">
        <div class="store-bullet">
            <img src="~/images/accent-bullet.svg" alt="" />
            <p>Our Store</p>
        </div>

        <h2>High quality fitness products built for results</h2>

        <div class="store-img">
            <img src="~/images/store-image-1.svg" alt="Store product 1" />
            <img src="~/images/store-image-2.svg" alt="Store product 2" />
            <img src="~/images/store-image-3.svg" alt="Store product 3" />
            <img src="~/images/store-image-4.svg" alt="Store product 4" />
        </div>

        <div class="store-description">
            <p>Let's make something great work together.</p>
            <a asp-controller="Home" asp-action="NotFoundPage" class="free-quote">Get Free Quote</a>
        </div>
    </div>
</section>