<header class="site-header">
    <div class="header-container">
        <div class="header-logo">
            <a asp-controller="Home" asp-action="Index">
                <img src="~/images/CoreFitnessLogo.svg" alt="Core Fitness Logo" />
            </a>
        </div>

        <nav class="header-nav">
            <a asp-controller="Home" asp-action="FitnessCenters">Fitness Centers</a>
            <a asp-controller="Home" asp-action="Memberships">Memberships</a>
            <a asp-controller="Home" asp-action="Training">Training</a>
            <a asp-controller="Home" asp-action="CustomerService">Customer Service</a>
            <a asp-controller="Home" asp-action="Store">Store</a>
        </nav>

        <div class="header-account">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <span>Hej @User.Identity.Name</span>

                <a asp-controller="MyPage" asp-action="Index" class="button">Min sida</a>

                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button class="button" type="submit">Logga ut</button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="button">Logga in</a>
                <a asp-controller="Account" asp-action="Register" class="button">Registrera</a>
            }
        </div>
    </div>
</header>
