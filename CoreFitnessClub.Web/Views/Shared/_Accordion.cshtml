@model List<CoreFitnessClub.Web.ViewModels.AccordionViewmodel>

<div class="accordion-bg">
    <div class="accordion-container">
        <div class="accordion-img">
            <img src="~/images/accordionimg.svg" alt="Accordion image" />
        </div>

        <article class="accordion">
            <div class="accordion-bullet">
                <img src="~/images/accent-bullet.svg" alt="" />
                <p>Frequently Asked Questions</p>
            </div>

            <div class="accordion-title">
                <h2>Common questions about gym and training</h2>
            </div>

            <div class="accordion-list">
                @foreach (var faq in Model)
                {
                    <div class="accordion-box" data-value="@faq.Id">
                        <span class="accordion-selected">
                            Q@(faq.Id). @faq.Question
                        </span>

                        <div class="accordion-arrow-circle">
                            <div class="accordion-arrow"></div>
                        </div>
                    </div>

                    <div class="accordion-descriptions" data-value="@faq.Id">
                        <div class="accordion-description">
                            @foreach (var answer in faq.Answers)
                            {
                                <p>@answer</p>
                            }
                        </div>
                    </div>

                    <div class="accordion-divider"></div>
                }
            </div>
        </article>
    </div>
</div>