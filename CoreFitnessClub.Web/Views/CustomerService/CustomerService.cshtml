@model CustomerServicePageViewModel

<div class="customer-service-container">
    <h1>Customer Service</h1>

    <div class="customer-service-form-container">
        <div class="customer-service-img-container">
            <div class="customer-service-img">
                <img src="~/images/customerServiceFormImg.svg" alt="Customer service" />

                <div class="customer-service-form-img-bullet-containers">
                    <div class="customer-service-form-img-bullet-container">
                        <div class="phone-icon">
                            <img src="~/images/phoneIcon.svg" alt="" />
                        </div>
                        <div class="customer-service-img-text">
                            <h3>Phone Number</h3>
                            <p>+(46) 8 410 521 00</p>
                        </div>
                    </div>

                    <div class="customer-service-form-img-bullet-container">
                        <div class="mail-icon">
                            <img src="~/images/mailIcon.svg" alt="" />
                        </div>
                        <div class="customer-service-img-text">
                            <h3>Email Address</h3>
                            <p>info@corefitness.se</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div>
            <div class="customer-service-form-title">
                <h2>Contact Us Today</h2>
                <p>Ready to begin your fitness journey? Contact CoreFitness today and let our expert trainers guide you with the right program and support.</p>
            </div>

            <form class="customer-service-form">
                <div class="customer-service-contact-info">
                    <div class="customer-service-input-container">
                        <label for="first-name">First name *</label>
                        <input type="text" id="first-name" name="first-name" required />
                    </div>

                    <div class="customer-service-input-container">
                        <label for="last-name">Last Name *</label>
                        <input type="text" id="last-name" name="last-name" required />
                    </div>
                </div>

                <div class="customer-service-contact-info">
                    <div class="customer-service-input-container">
                        <label for="email">Email *</label>
                        <input type="email" id="email" name="email" required />
                    </div>

                    <div class="customer-service-input-container">
                        <label for="phoneNumber">Phone Number</label>
                        <input type="tel" id="phoneNumber" name="phoneNumber" />
                    </div>
                </div>

                <label for="message">Message</label>
                <textarea id="message" name="message" rows="5" required></textarea>

                <button class="customer-service-submit-btn" type="button">
                    Submit Message &gt;
                </button>
            </form>
        </div>
    </div>
</div>

@await Html.PartialAsync("_Accordion", Model.AccordionItems)