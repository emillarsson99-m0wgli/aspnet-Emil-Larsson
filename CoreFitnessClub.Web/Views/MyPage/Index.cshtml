@model CoreFitnessClub.Web.ViewModels.MyPageViewModel
@{
    ViewData["Title"] = "My Account";
}

<main>
    <h1 class="site-h1">My Account</h1>

    <div class="account-container">

        <div class="account-sidebar">
            <img src="~/images/AccountImg.svg" alt="Account Image" />

            <div class="account-menu-options">
                <p>Menu Options</p>

                <a class="menu-option" asp-controller="Account" asp-action="MyPage">
                    About me <span>></span>
                </a>

                <hr class="account-menu-hr" />

                <a class="menu-option" asp-controller="Memberships" asp-action="MyMembership">
                    My Membership <span>></span>
                </a>

                <hr class="account-menu-hr" />

                <a class="menu-option" asp-controller="Bookings" asp-action="MyBookings">
                    My Bookings <span>></span>
                </a>

                <hr class="account-menu-hr" />

                <form asp-controller="Account" asp-action="Logout" method="post" class="logout-form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-menu-option">
                        <span>Sign Out</span>
                        <span>></span>
                    </button>
                </form>
            </div>

            <div class="account-delete">
                <p>If you like to cancel your account click below</p>

                <form asp-controller="Account" asp-action="DeleteAccount" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="delete-button">Remove Account</button>
                </form>
            </div>
        </div>

        <div class="account-content">

            <div class="account-card">
                <h1>About Me</h1>

                <hr class="account-hr" />

                <form asp-controller="Account" asp-action="UpdateProfile" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="form-group" id="form-group-top">
                        <label asp-for="FirstName"></label>
                        <input asp-for="FirstName" placeholder="Enter First Name" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="LastName"></label>
                        <input asp-for="LastName" placeholder="Enter Last Name" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" placeholder="username@domain.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="form-group" id="form-group-bottom">
                        <label asp-for="PhoneNumber"></label>
                        <input asp-for="PhoneNumber" placeholder="Enter Phone Number" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>

                    <hr class="account-hr" />

                    <div class="form-group" id="file-input">
                        <label for="ProfileImage">Profile Image</label>

                        <input type="file" id="ProfileImage" name="ProfileImage" accept="image/*" />

                        <label for="ProfileImage" class="upload-box">
                            <span>Upload Profile Image</span>
                            <span class="browse-btn">Browse</span>
                        </label>
                    </div>

                    <div class="button-row">
                        <button type="submit" class="save-button">
                            Save <span>›</span>
                        </button>
                    </div>
                </form>
            </div>

            <div class="account-statistics">
                <h2>My Statistics</h2>

                <div class="statistics-items">
                    <div class="statistic-item">
                        <p>Check-In (last 30 days)</p>
                    </div>

                    <div class="statistic-item">
                        <p>Weight Goal</p>
                    </div>

                    <div class="statistic-item">
                        <p>Current BMI</p>
                    </div>
                </div>
            </div>

        </div>

    </div>
</main>