@model CoreFitnessClub.Web.ViewModels.VerifyExternalLoginViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/VerifyExternalLogin.css" asp-append-version="true" />
}

<section class="verify-container">
    <div class="verify-card">

        <div class="verify-message">
            <h1>Verify your email</h1>
            <p>
                A verification code has been sent to <strong>@Model.Email</strong>
            </p>
            <p>Demo code: <strong>12345</strong></p>
        </div>

        <hr class="verify-hr" />

        <form asp-controller="Account" asp-action="VerifyExternalLogin" method="post" class="verify-form">
            <input asp-for="Email" type="hidden" />
            <input asp-for="ReturnUrl" type="hidden" />

            <div class="verify-group">
                <label asp-for="Code">Verification code:</label>
                <input asp-for="Code" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <p class="verify-info">
                By verifying, you agree to our
                <a href="/terms">terms of service</a> and
                <a href="/privacy">privacy policy</a>.
            </p>

            <div class="verify-button-row">
                <button type="submit" class="verify-button">
                    Verify <span>›</span>
                </button>
            </div>
        </form>

    </div>
</section>
