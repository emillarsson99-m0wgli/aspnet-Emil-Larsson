@model CoreFitnessClub.Web.ViewModels.VerifyExternalLoginViewModel

<section class="flex-column align-items-center justify-center px-4 py-36">
    <div class="max-w-215 bg-white rounded-[20px] shadow-sm p-16 flex-column flex-column gap-8">
        <div class="space-y-2">
            <h1>Verify your email</h1>
            <p>
                A verification code has been sent to <strong>@Model.Email</strong>
            </p>
            <p>Demo code: <strong>12345</strong></p>
        </div>
        <hr class="border-t border-gray-light" />
        <form asp-controller="Account" asp-action="VerifyExternalLogin" method="post" class="flex-column flex-column gap-4">
            <input asp-for="Email" type="hidden" />
            <input asp-for="ReturnUrl" type="hidden" />

            <div class="flex flex-column gap-2">
                <label asp-for="Code">Verification code:</label>
                <input asp-for="Code" class="border border-gray-light rounded-[10px] p-2" />
                <span asp-validation-for="Code" class="text-red-500 text-sm"></span>
            </div>

            <p class="text-sm-center text-gray-500">
                By verifying, you agree to our
                <a href="/terms" class="underline">terms of service</a> and
                <a href="/privacy" class="underline">privacy policy</a>.
            </p>

            <button type="submit" class="card-header-tabs modal-fullscreen-lg-down justify-center">
                Verify
                <svg width="8" height="15" viewBox="0 0 8 15" fill="none" xmlns="http://www.w3.org/2000/svg"></svg>
                    <path></path>
            </button>
        </form>
    </div>
</section>
