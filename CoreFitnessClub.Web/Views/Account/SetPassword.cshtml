@model CoreFitnessClub.Web.ViewModels.Account.SetPasswordViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/SetPassword.css" />
}

<div class="set-password-container">
    <div class="set-password-card">

        <div class="set-password-message">
            <h1>Set Your Password</h1>
            <p>
                Set a strong password to protect your account. For security reasons, your password must be at least 8 characters long and include uppercase and lowercase letters, numbers, and special characters.
            </p>
        </div>

        <hr class="set-password-hr" />

        <form asp-controller="Account" asp-action="SetPassword" method="post" class="set-password">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="set-password-group">
                <label>Email Address *</label>
                <input type="email" value="@ViewBag.Email" disabled />
            </div>

            <div class="set-password-group">
                <label asp-for="Password">Password *</label>
                <input asp-for="Password" type="password" placeholder="Enter your password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="set-password-group">
                <label asp-for="ConfirmPassword">Confirm Password *</label>
                <input asp-for="ConfirmPassword" type="password" placeholder="Confirm your password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <label class="terms-and-conditions">
                <input asp-for="AcceptTerms" type="checkbox" />
                <span class="custom-checkbox"></span>
                Accept user terms and conditions
            </label>
            <span asp-validation-for="AcceptTerms" class="text-danger"></span>

            <div class="set-password-button-row">
                <button type="submit" class="set-password-button">
                    Continue <span>></span>
                </button>
            </div>
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}