@model List<CoreFitnessClub.Domain.Entities.WorkoutClass>

@{
    ViewData["Title"] = "Träningspass";
}

<section class="classes-page">
    <div class="classes-header">
        <h1>Classes</h1>
        <p>Choose a class and book your spot!</p>
    </div>

    @if (!Model.Any())
    {
        <p>There are currently no classes available.</p>
    }
    else
    {
        <div class="classes-grid">
            @foreach (var item in Model)
            {
                <article class="class-card">
                    <div class="class-card-header">
                        <span class="class-category">@item.Category</span>
                        <h2>@item.Name</h2>
                    </div>

                    <div class="class-card-body">
                        <p><strong>Instructor:</strong> @item.Instructor</p>
                        <p><strong>Date:</strong> @item.Date.ToShortDateString()</p>
                        <p><strong>Time:</strong> @item.StartTime.ToString(@"hh\:mm") - @item.EndTime.ToString(@"hh\:mm")</p>
                        <p><strong>Spots:</strong> @item.Capacity</p>
                    </div>

                    <form asp-controller="Bookings" asp-action="Book" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="workoutClassId" value="@item.Id" />
                        <button type="submit" class="book-button">Book class</button>
                    </form>
                </article>
            }
        </div>
    }
</section>